<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ðŸ”’ PROXY API REQUESTS (HIDE BACKEND DOMAIN)
  RewriteRule ^api/(.*)$ https://ishivaxapi.ishivax.com/api/$1 [P,L]

  ProxyPassReverse /api/ https://ishivaxapi.ishivax.com/api/

  # React routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# REQUIRED for proxy
<IfModule mod_proxy.c>
  ProxyPreserveHost On
</IfModule>